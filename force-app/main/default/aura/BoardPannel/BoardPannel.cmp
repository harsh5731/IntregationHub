<aura:component
    implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId"
    access="global">

    <aura:attribute name="Modes" type="List" default="[
    {'label': 'Easy', 'value': 'easy'},
    {'label': 'Medium', 'value': 'medium'},
    {'label': 'Hard', 'value': 'hard'}
    ]" />

    <aura:attribute name="selectedMode" type="String" default="" />

    <lightning:card title="Word Shuffle">

        <lightning:layout horizontalAlign="center">
            <lightning:layoutItem padding="around-small">
                <lightning:combobox name="gameMode" label="Game Mode" aura:id="gameMode" variant="label-hidden" value="" placeholder="Select Game Mode"
                    options="{! v.Modes }" />

            </lightning:layoutItem>


            <lightning:layoutItem padding="around-small">
                <lightning:button variant="brand" label="Start New Game" title="Start New Game" onclick ="{!c.startNewGame}" />

            </lightning:layoutItem>


            <lightning:layoutItem padding="around-small">
                <lightning:button variant="neutral" label="Reshuffle" title="Reshuffle" onclick="{!c.reshuffleWords}" />

            </lightning:layoutItem>

        </lightning:layout>

        Selected Game Mode : {!v.selectedMode}

    </lightning:card>

</aura:component>